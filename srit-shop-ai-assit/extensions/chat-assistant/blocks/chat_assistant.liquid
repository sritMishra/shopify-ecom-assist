{% comment %}
  AI Shopping Assistant — app embed block.
  target: "body" → loads app-wide as a floating widget (toggled on under
  Theme editor → App embeds). Settings are passed to the JS via data-* attrs.
{% endcomment %}

<div
  id="srit-chat-root"
  data-shop="{{ shop.permanent_domain }}"
  data-greeting="{{ block.settings.greeting | escape }}"
  data-title="{{ block.settings.panel_title | escape }}"
  data-accent="{{ block.settings.accent | default: '#5c6ac4' }}"
></div>

{{ 'chat-assistant.css' | asset_url | stylesheet_tag }}
<script src="{{ 'chat-assistant.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "AI Shopping Assistant",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "panel_title",
      "label": "Chat title",
      "default": "Shopping Assistant"
    },
    {
      "type": "text",
      "id": "greeting",
      "label": "Greeting message",
      "default": "Hi! Tell me what you're looking for and I'll find it."
    },
    {
      "type": "color",
      "id": "accent",
      "label": "Accent color",
      "default": "#5c6ac4"
    }
  ]
}
{% endschema %}
