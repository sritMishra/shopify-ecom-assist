PORT=3001
NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopify_assistant

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2024-01
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# App client secret (Partners dashboard → your app → API credentials).
# Used to verify Shopify App Proxy request signatures on /api/storefront/*.
SHOPIFY_API_SECRET=
